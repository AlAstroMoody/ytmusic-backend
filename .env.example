# Скопировать в .env и заполнить. browser.json/oauth.json — вручную на сервер.
AUTH_FILE=browser.json

# Только для oauth.json:
# AUTH_FILE=oauth.json
# YTM_CLIENT_ID=your-client-id.apps.googleusercontent.com
# YTM_CLIENT_SECRET=your-client-secret

# Bounded in-memory cache for googlevideo URLs (per gunicorn worker)
STREAM_URL_CACHE_MAX=96
STREAM_URL_CACHE_TTL=600
