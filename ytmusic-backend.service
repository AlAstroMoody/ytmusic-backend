[Unit]
Description=YTMusic Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ytmusic-backend
EnvironmentFile=/opt/ytmusic-backend/.env
ExecStart=/opt/ytmusic-backend/venv/bin/gunicorn -w 2 -k gthread -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=3
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
